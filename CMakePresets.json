{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "mingw-base",
      "hidden": true,
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "D:/APP/Mingw-64/Mingw-64/ucrt64/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "D:/APP/Mingw-64/Mingw-64/ucrt64/bin/g++.exe",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "mingw-debug",
      "inherits": "mingw-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "PLATFORM_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "mingw-release",
      "inherits": "mingw-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "PLATFORM_BUILD_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "mingw-debug",
      "configurePreset": "mingw-debug"
    },
    {
      "name": "mingw-release",
      "configurePreset": "mingw-release"
    }
  ],
  "testPresets": [
    {
      "name": "mingw-debug",
      "configurePreset": "mingw-debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}

